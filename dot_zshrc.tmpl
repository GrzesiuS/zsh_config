# Portable PATH
export PATH="$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

ZSH_DISABLE_COMPFIX="true"
export ZSH="$HOME/.oh-my-zsh"

export GEMINI_API_KEY="{{ (include "gemini_api_key.txt.asc" | decrypt) | trim }}"
export ZSH_AI_PROVIDER="gemini"

# Plugins from your config (standard OMZ + external ones)
plugins=(
    chezmoi git aliases command-not-found cp extract brew 
    zsh-autosuggestions fast-syntax-highlighting you-should-use zoxide zsh-ai
)

source $ZSH/oh-my-zsh.sh

# Rest of your config...
export EDITOR='micro'
export PATH="$HOME/bin:$PATH"

if [ -f "$HOME/.oh_my_posh.json" ]; then
    eval "$(oh-my-posh init zsh --config ~/.oh_my_posh.json)"
fi

alias edit=micro
